general {
        output_format = "i3bar"
        colors = false
        markup = pango
        interval = 5
        color_good = '#2f343f'
		color_degraded = '#ebcb8b'
		color_bad = '#ba5e57'
}

order += "tztime local"

tztime local {
		format = "<span foreground='#ffffff'> %time </span>"
		format_time = "- %A %-d %b %Y %H:%M"
}

